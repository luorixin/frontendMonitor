{
  "name": "frontend-monitor-react",
  "version": "2.0.0",
  "private": false,
  "description": "React adapter for the frontend-monitor browser SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "frontend-monitor-core": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "monitoring",
    "frontend",
    "sdk",
    "react",
    "tracing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luorixin/frontendMonitor.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/luorixin/frontendMonitor/issues"
  },
  "homepage": "https://github.com/luorixin/frontendMonitor/tree/master/packages/react",
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts"
  }
}
