{
  "name": "frontend-monitor-vue3",
  "version": "2.0.0",
  "private": false,
  "description": "Vue 3 adapter for the frontend-monitor browser SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "frontend-monitor-core": "workspace:^"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "monitoring",
    "frontend",
    "sdk",
    "vue3",
    "tracing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luorixin/frontendMonitor.git",
    "directory": "packages/vue3"
  },
  "bugs": {
    "url": "https://github.com/luorixin/frontendMonitor/issues"
  },
  "homepage": "https://github.com/luorixin/frontendMonitor/tree/master/packages/vue3",
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts"
  }
}
